---
import type { DataSourceObjectResponse } from "@notionhq/client/build/src/api-endpoints";
import DevOnly from "../../DevOnly.astro";

export interface Props {
  property: DataSourceObjectResponse["properties"][""];
}

const { property } = Astro.props;
---

<DevOnly>
  property {property.id} has type {property.type}
</DevOnly>
