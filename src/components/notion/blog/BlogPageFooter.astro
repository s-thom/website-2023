---
import { type DatabaseObjectResponse } from "@notionhq/client/build/src/api-endpoints";
import { getRelatedPosts } from "../../../integrations/related-posts";
import { BLOG_PAGE_ID } from "../../../lib/constants";
import { getPagesCollection } from "../../../lib/notion/collections";
import BlogListPageItem from "./BlogListPageItem.astro";

export interface Props {
  page: DatabaseObjectResponse;
}

const { page } = Astro.props;

const blogIndexEntries = await getPagesCollection(
  (entry) => entry.id === BLOG_PAGE_ID,
);
const blogEntries = await getPagesCollection(
  (entry) =>
    entry.data.properties.Type?.name === "blog" &&
    entry.data.properties.Status?.name === "Listed",
);

type EntryType = (typeof blogEntries)[number];

// Get next/previous entries
let next: EntryType | undefined;
let prev: EntryType | undefined;
const index = blogEntries.findIndex((curr) => curr.id === page.id);
if (index !== -1) {
  if (index !== 0) {
    next = blogEntries[index - 1];
  }
  if (index !== blogEntries.length - 1) {
    prev = blogEntries[index + 1];
  }
}

const relatedLinks = await getRelatedPosts("blog-posts", page.id);
const relatedPages = relatedLinks
  .map((related) => blogEntries.find((entry) => entry.id === related.id))
  .filter((entry) => entry !== undefined)
  .reduce<Record<string, EntryType>>((obj, curr) => {
    obj[curr.id] = curr;
    return obj;
  }, {});
---

<div class="blog-footer big-box-margin">
  {
    relatedLinks.length > 0 && (
      <div class="links">
        {relatedLinks.map((rel) => (
          <BlogListPageItem
            page={relatedPages[rel.id].data.page}
            slug={relatedPages[rel.id].data.slug}
            showTitle
          >
            <Fragment slot="info-top">
              <span
                class="pre-title"
                data-similarity={Math.floor(rel.similarity * 100)}
              >
                Related
              </span>
            </Fragment>
          </BlogListPageItem>
        ))}
      </div>
    )
  }
  <div class="links static-links">
    <div
      class:list={["links-box next", !next && "big-corners big-box-border "]}
    >
      {
        next ? (
          <BlogListPageItem
            page={next.data.page}
            slug={next.data.slug}
            showTitle
          >
            <Fragment slot="info-top">
              <span class="pre-title">Next post</span>
            </Fragment>
          </BlogListPageItem>
        ) : (
          <p>You've reached the end of this blog!</p>
        )
      }
    </div>
    <div
      class:list={["links-box prev", !prev && "big-corners big-box-border "]}
    >
      {
        prev ? (
          <BlogListPageItem
            page={prev.data.page}
            slug={prev.data.slug}
            showTitle
          >
            <Fragment slot="info-top">
              <span class="pre-title">Previous post</span>
            </Fragment>
          </BlogListPageItem>
        ) : (
          <p>You've reached the end of this blog!</p>
        )
      }
    </div>
    <div class="links-box up">
      {
        blogIndexEntries.length === 1 && (
          <BlogListPageItem
            page={blogIndexEntries[0].data.page}
            slug=""
            showTitle
          >
            <Fragment slot="info-top">
              <span class="pre-title">More posts</span>
            </Fragment>
          </BlogListPageItem>
        )
      }
    </div>
  </div>
</div>

<style>
  .links {
    display: grid;
    gap: var(--spacing);
    grid-template-columns: repeat(1, 1fr);
  }

  .static-links {
    grid-template-areas:
      "next"
      "prev"
      "up";
  }

  .links-box {
    position: relative;
  }

  .next,
  .prev {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .next {
    grid-area: next;
  }
  .prev {
    grid-area: prev;
  }
  .up {
    grid-area: up;
  }

  @media (min-width: 900px) {
    .links {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        "prev next"
        "up up";
    }

    .static-links {
      grid-template-areas:
        "prev next"
        "up up";
    }
  }

  .pre-title {
    align-self: flex-start;
    font-size: var(--size-step-min1);
    font-style: italic;
    color: var(--color-text-header);
  }
</style>
