<script>
  let loaded = false;
  const start = async () => {
    if (loaded) {
      return;
    }
    loaded = true;

    // Only download main script Javascript if required
    (await import("../../lib/web3IsAScam")).web3IsAScam();
  };
  const startAndTrack = () => {
    start();
    if (typeof umami !== "undefined") {
      umami.track("web3IsAScam");
    }
  };

  if (
    "etherium" in window ||
    "web3" in window ||
    "solana" in window ||
    "wallets" in window ||
    "wallets" in window.navigator ||
    localStorage.getItem("simulate-hell") === "true"
  ) {
    startAndTrack();
  } else {
    window.addEventListener("eip6963:announceProvider", startAndTrack);
    window.addEventListener("wallet-standard:register-wallet", startAndTrack);
    window.addEventListener("mock-web3isascam", start); // No tracking for mock
    window.dispatchEvent(new Event("eip6963:requestProvider"));
    window.dispatchEvent(new Event("wallet-standard:app-ready"));
  }
</script>
