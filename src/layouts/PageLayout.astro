---
import { Font } from "astro:assets";
import PageMeta from "../components/PageMeta.astro";
import Web3IsAScam from "../components/site/Web3IsAScam.astro";
import "../css/index.css";
import type { PageMetaType } from "../lib/site/PageMeta";
import MinimalLayout from "./MinimalLayout.astro";
import type { JSX } from "astro/jsx-runtime";

export interface Props {
  id: string;
  meta: PageMetaType;
  htmlStyle?: JSX.HtmlHTMLAttributes["style"];
}

const { meta, htmlStyle } = Astro.props;
---

<MinimalLayout htmlStyle={htmlStyle}>
  <Fragment slot="head">
    <PageMeta meta={meta} />
    <Font
      cssVariable="--font-parclo-serif"
      preload={[
        { style: "italic", weight: 975 },
        { style: "normal", weight: 400 },
        { style: "normal", weight: 700 },
      ]}
    />
    <Font cssVariable="--font-source-code" />
    <Font cssVariable="--font-trunic" />
    <slot name="head" />
    <Web3IsAScam />
  </Fragment>

  <slot name="top" />
  <slot name="skip-links" />

  <slot name="site-header" />

  <slot />

  <slot name="page-footer" />
  <slot name="site-footer" />
</MinimalLayout>
